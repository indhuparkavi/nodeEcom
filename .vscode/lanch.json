{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "smartStep": true,
            "sourceMaps": true,
            "program": "${workspaceFolder}/dist/",
            "restart": true,
            "runtimeExecutable": "nodemon",
            "preLaunchTask": "BuildBoth",
            "outFiles": [
                "${workspaceFolder}/dist/src/**/*.js"
            ]
        }
    ]
}